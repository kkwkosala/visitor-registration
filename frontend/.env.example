# Supabase connection — copy this file to environment.ts and fill in your values
# Get credentials from: https://supabase.com → Your Project → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# NEVER commit the real values — add environment.ts to .gitignore if needed
# The anon key is safe to use in the browser (it is public by design)
# NEVER use the service_role key in the frontend
